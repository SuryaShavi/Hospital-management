{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*"]
    },
    "types": [
      "jest",
      "node",
      "@testing-library/jest-dom",
      "@playwright/test",
      "react",
      "react-dom",
      "react-router-dom",
      "supertest",
      "lodash"
    ]
  },
  "include": [
    "backend/**/*.ts",
    "frontend/**/*.ts",
    "frontend/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "../frontend/src/**/*"
  ]
}